# Primary LLM provider — Google Gemini API
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Fallback / alternative provider — OpenRouter
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Models (override defaults if needed)
# Provider: "openrouter" (recommended — many cheap models) or "gemini" (direct)
LLM_PROVIDER=openrouter

# Per-step models. Defaults below are cheap and stable on OpenRouter.
# Override in UI's Settings panel without restarting the server.
MODEL_FAST=qwen/qwen-2.5-72b-instruct
MODEL_SMART=deepseek/deepseek-chat-v3-0324
